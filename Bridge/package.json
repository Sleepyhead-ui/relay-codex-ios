{
  "name": "relay-codex-bridge",
  "version": "0.8.0",
  "private": true,
  "description": "Authenticated local bridge between Relay for iOS and Codex App Server",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "npm run build && node --test test/*.test.mjs",
    "test:e2e": "npm run build && node test/bridge-e2e.mjs",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@openai/codex": "0.144.5",
    "qrcode-terminal": "0.12.0",
    "ws": "8.21.1"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "@types/qrcode-terminal": "0.12.2",
    "@types/ws": "8.18.1",
    "tsx": "4.20.3",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=22"
  }
}
